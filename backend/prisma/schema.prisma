// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(255)
  nome         String   @db.VarChar(100)
  criadoEm     DateTime @default(now()) @map("criado_em") @db.Timestamptz
  atualizadoEm DateTime @updatedAt @map("atualizado_em") @db.Timestamptz

  atividades Atividade[]

  @@map("usuarios")
}

model Atividade {
  id           String      @id @default(uuid()) @db.Uuid
  usuarioId    String      @map("usuario_id") @db.Uuid
  nome         String      @db.VarChar(100)
  tipoMedicao  TipoMedicao @map("tipo_medicao")
  arquivada    Boolean     @default(false)
  criadoEm     DateTime    @default(now()) @map("criado_em") @db.Timestamptz
  atualizadoEm DateTime    @updatedAt @map("atualizado_em") @db.Timestamptz

  usuario        Usuario         @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  categorias     Categoria[]
  sessoes        Sessao[]
  configPomodoro ConfigPomodoro?

  @@index([usuarioId])
  @@unique([usuarioId, nome], map: "idx_atividades_nome_unico")
  @@map("atividades")
}

model Categoria {
  id           String   @id @default(uuid()) @db.Uuid
  atividadeId  String   @map("atividade_id") @db.Uuid
  nome         String   @db.VarChar(100)
  cor          String   @default("#6366F1") @db.VarChar(7)
  ordem        Int      @default(0)
  arquivada    Boolean  @default(false)
  criadoEm     DateTime @default(now()) @map("criado_em") @db.Timestamptz
  atualizadoEm DateTime @updatedAt @map("atualizado_em") @db.Timestamptz

  atividade Atividade @relation(fields: [atividadeId], references: [id], onDelete: Cascade)
  sessoes   Sessao[]

  @@index([atividadeId])
  @@unique([atividadeId, nome], map: "idx_categorias_nome_unico")
  @@map("categorias")
}

model Sessao {
  id              String     @id @default(uuid()) @db.Uuid
  atividadeId     String     @map("atividade_id") @db.Uuid
  categoriaId     String?    @map("categoria_id") @db.Uuid
  iniciadoEm      DateTime   @map("iniciado_em") @db.Timestamptz
  duracaoSegundos Int        @default(0) @map("duracao_segundos")
  modo            ModoSessao
  ciclosPomodoro  Int?       @map("ciclos_pomodoro")
  observacoes     String?    @db.Text
  criadoEm        DateTime   @default(now()) @map("criado_em") @db.Timestamptz

  atividade Atividade  @relation(fields: [atividadeId], references: [id], onDelete: Cascade)
  categoria Categoria? @relation(fields: [categoriaId], references: [id], onDelete: SetNull)

  @@index([atividadeId, iniciadoEm(sort: Desc)], map: "idx_sessoes_atividade_inicio")
  @@index([categoriaId, iniciadoEm(sort: Desc)], map: "idx_sessoes_categoria_inicio")
  @@index([iniciadoEm(sort: Desc)], map: "idx_sessoes_inicio")
  @@map("sessoes")
}

model ConfigPomodoro {
  id                String @id @default(uuid()) @db.Uuid
  atividadeId       String @unique @map("atividade_id") @db.Uuid
  minutosFoco       Int    @default(25) @map("minutos_foco")
  minutosPausaCurta Int    @default(5) @map("minutos_pausa_curta")
  minutosPausaLonga Int    @default(15) @map("minutos_pausa_longa")
  ciclosAntesLonga  Int    @default(4) @map("ciclos_antes_longa")

  atividade Atividade @relation(fields: [atividadeId], references: [id], onDelete: Cascade)

  @@map("config_pomodoro")
}