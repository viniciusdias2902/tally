// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(255)
  nome         String   @db.VarChar(100)
  criadoEm     DateTime @default(now()) @map("criado_em") @db.Timestamptz
  atualizadoEm DateTime @updatedAt @map("atualizado_em") @db.Timestamptz

  atividades Atividade[]

  @@map("usuarios")
}

model Atividade {
  id           String      @id @default(uuid()) @db.Uuid
  usuarioId    String      @map("usuario_id") @db.Uuid
  nome         String      @db.VarChar(100)
  tipoMedicao  TipoMedicao @map("tipo_medicao")
  arquivada    Boolean     @default(false)
  criadoEm     DateTime    @default(now()) @map("criado_em") @db.Timestamptz
  atualizadoEm DateTime    @updatedAt @map("atualizado_em") @db.Timestamptz

  usuario        Usuario         @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  categorias     Categoria[]
  sessoes        Sessao[]
  configPomodoro ConfigPomodoro?

  @@index([usuarioId])
  @@unique([usuarioId, nome], map: "idx_atividades_nome_unico")
  @@map("atividades")
}

model Categoria {
  id           String   @id @default(uuid()) @db.Uuid
  atividadeId  String   @map("atividade_id") @db.Uuid
  nome         String   @db.VarChar(100)
  cor          String   @default("#6366F1") @db.VarChar(7)
  ordem        Int      @default(0)
  arquivada    Boolean  @default(false)
  criadoEm     DateTime @default(now()) @map("criado_em") @db.Timestamptz
  atualizadoEm DateTime @updatedAt @map("atualizado_em") @db.Timestamptz

  atividade Atividade @relation(fields: [atividadeId], references: [id], onDelete: Cascade)
  sessoes   Sessao[]

  @@index([atividadeId])
  @@unique([atividadeId, nome], map: "idx_categorias_nome_unico")
  @@map("categorias")
}