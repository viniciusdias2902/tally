# ── Banco de dados ────────────────────────────────────────
# Em produção o host deve ser o nome do serviço no docker-compose (ex: postgres)
DATABASE_URL="postgresql://POSTGRES_USER:POSTGRES_PASSWORD@postgres:5432/POSTGRES_DB?schema=public"
POSTGRES_USER=tally
POSTGRES_PASSWORD=troque_essa_senha
POSTGRES_DB=tally_db

# ── JWT ───────────────────────────────────────────────────
# Gere segredos fortes: node -e "require('crypto').randomBytes(64).toString('base64') |> console.log"
JWT_SECRET=gere_um_segredo_forte_aqui
JWT_REFRESH_SECRET=gere_outro_segredo_forte_aqui
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_IN=7d
JWT_REFRESH_TOKEN_MAX_EXPIRES_IN=30d

# ── Servidor ──────────────────────────────────────────────
PORT=3000
# URL base da API (usada pelo Swagger). Em produção: https://viniciusdias.tech/tally/api
API_BASE_URL=http://localhost:3000
