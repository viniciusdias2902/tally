meta {
  name: Criar/Atualizar Config Pomodoro
  type: http
  seq: 2
}

put {
  url: {{baseUrl}}/atividades/{{atividadeId}}/config-pomodoro
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "minutosFoco": 25,
    "minutosPausaCurta": 5,
    "minutosPausaLonga": 15,
    "ciclosAntesLonga": 4
  }
}
