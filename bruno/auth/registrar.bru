meta {
  name: Registrar
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/auth/registrar
  body: json
  auth: none
}

body:json {
  {
    "email": "teste@email.com",
    "nome": "Usuário Teste",
    "senha": "senha1234"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("accessToken", res.body.accessToken);
    bru.setVar("refreshToken", res.body.refreshToken);
  }
}
