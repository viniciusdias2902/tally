meta {
  name: Criar Atividade
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/atividades
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "nome": "Atividade teste",
    "tipoMedicao": "cronometrada"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("atividadeId", res.body.id);
  }
}
