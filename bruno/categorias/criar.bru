meta {
  name: Criar Categoria
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/atividades/{{atividadeId}}/categorias
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "nome": "Categoria teste",
    "cor": "#6366F1"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("categoriaId", res.body.id);
  }
}
